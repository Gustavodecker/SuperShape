{
  "expo": {
    "name": "SuperShape",
    "slug": "supershape",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "supershape",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gustavomiguel.supershape"
    },
    "android": {
      "package": "com.gustavomiguel.supershape"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d961d01e-b71b-4f06-a340-e052fcf8ae05"
      }
    },
    "owner": "gustavo.miguel"
  }
}
